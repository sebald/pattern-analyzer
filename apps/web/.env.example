# =============================================================================
# Database (MySQL via PlanetScale / Kysely)
# =============================================================================
DATABASE_HOST=
DATABASE_USERNAME=
DATABASE_PASSWORD=

# Connection pool size (optional, defaults to 1)
# The setup-database script overrides this to 10 for bulk imports.
# DB_POOL_SIZE=1

# =============================================================================
# App URL
# =============================================================================
# Set ONE of these. NEXT_PUBLIC_APP_URL takes priority.
# On Vercel, NEXT_PUBLIC_VERCEL_URL is set automatically.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_VERCEL_URL=

# =============================================================================
# Sync API authentication
# =============================================================================
# Token required by POST /api/sync to authorize database syncs.
SYNC_TOKEN=

# =============================================================================
# Analytics (optional)
# =============================================================================
# Google Analytics measurement ID
# NEXT_PUBLIC_GA_MEASUREMENT_ID=
