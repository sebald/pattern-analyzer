{
  "name": "@pattern-analyzer/xws",
  "version": "2.0.0",
  "description": "XWS normalization, game data lookups, and YASB integration for X-Wing Miniatures",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sebald/pattern-analyzer",
    "directory": "packages/xws"
  },
  "exports": {
    "./xws": {
      "types": "./dist/xws.d.ts",
      "import": "./dist/xws.js"
    },
    "./yasb": {
      "types": "./dist/yasb.d.ts",
      "import": "./dist/yasb.js"
    },
    "./get-value": {
      "types": "./dist/get-value.d.ts",
      "import": "./dist/get-value.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./data/ship-icons": {
      "types": "./dist/data/ship-icons.d.ts",
      "import": "./dist/data/ship-icons.js"
    },
    "./data/display-values": {
      "types": "./dist/data/display-values.d.ts",
      "import": "./dist/data/display-values.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "update:yasb": "zx scripts/update-yasb-data.mjs",
    "update:xwing": "zx scripts/update-xwing-data.mjs"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^3.1.0",
    "xwing-data2": "github:gregkash16/xwing-data2#7fc3f76",
    "yasb": "github:raithos/xwing#41a5a11",
    "zx": "7.2.3"
  }
}
